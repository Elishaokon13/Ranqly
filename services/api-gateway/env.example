# Environment Configuration
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://ranqly:ranqly_dev_password@localhost:5432/ranqly_dev
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://ranqly:ranqly_dev_password@localhost:27017/ranqly_logs

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://localhost:8545
POI_NFT_CONTRACT_ADDRESS=
CONTEST_VAULT_CONTRACT_ADDRESS=
PRIVATE_KEY=

# Message Queue Configuration
RABBITMQ_URL=amqp://ranqly:ranqly_dev_password@localhost:5672

# IPFS Configuration
IPFS_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# External API Keys
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_API_KEY=
LINKEDIN_API_SECRET=
GITHUB_API_KEY=

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,text/markdown

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@ranqly.com

# Security Configuration
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=true

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_LOG_LEVEL=info
